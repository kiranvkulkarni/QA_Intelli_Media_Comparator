# QA Intelli Media Comparator — Environment Configuration Reference
# Copy this file to .env and adjust for your environment.
# ──────────────────────────────────────────────────────────────────────────────
#
# QUALITY PROFILES  — set QIMC_QUALITY_PROFILE to one of:
#
#   low      Unstable rig / outdoor / handheld / CoreXY rail vibration
#            SSIM≥0.35  PSNR≥12dB   LPIPS≤0.60  Blur≥40   Noise≤20
#
#   medium   Semi-stable indoor / lightbox with minor vibration
#            SSIM≥0.60  PSNR≥20dB   LPIPS≤0.40  Blur≥70   Noise≤12
#
#   high     Stable lightbox + tripod — default for controlled camera QA
#            SSIM≥0.80  PSNR≥28dB   LPIPS≤0.20  Blur≥100  Noise≤8
#
#   critical Robotic / pixel-aligned rig / professional studio
#            SSIM≥0.92  PSNR≥35dB   LPIPS≤0.08  Blur≥150  Noise≤4
#
# When QIMC_QUALITY_PROFILE is set, all individual threshold settings below
# are overridden by the preset. Leave it empty to set thresholds manually.
# ──────────────────────────────────────────────────────────────────────────────
QIMC_QUALITY_PROFILE=high

# ── Compute ────────────────────────────────────────────────────────────────────
# "auto" detects CUDA automatically; force with "cuda" or "cpu"
QIMC_DEVICE=auto

# ── No-Reference IQA ───────────────────────────────────────────────────────────
# Classical NR metrics — always available, CPU-friendly
QIMC_NR_METRICS=brisque,niqe
# Set true to also run neural NR metrics (MUSIQ or CLIP-IQA); GPU recommended
QIMC_USE_NEURAL_NR=false
# Neural metric to use when QIMC_USE_NEURAL_NR=true  (musiq | clipiqa+)
QIMC_NEURAL_NR_METRIC=musiq

# ── Full-Reference IQA ─────────────────────────────────────────────────────────
# Metrics to compute when a reference file is provided (comma-separated)
# Options: ssim  ms_ssim  psnr  lpips  dists
QIMC_FR_METRICS=ssim,psnr,lpips

# ── Manual Thresholds (ignored when QIMC_QUALITY_PROFILE is set) ──────────────
# Uncomment these only if QIMC_QUALITY_PROFILE is empty/commented out.
#
# FR-IQA pass thresholds
#QIMC_SSIM_THRESHOLD=0.85       # structural similarity  (0–1, higher = better)
#QIMC_PSNR_THRESHOLD=30.0       # peak signal-to-noise   (dB, higher = better)
#QIMC_LPIPS_THRESHOLD=0.15      # perceptual distance     (0–1, lower  = better)
#QIMC_DISTS_THRESHOLD=0.15      # texture/style distance  (0–1, lower  = better)
#
# Standard quality thresholds
#QIMC_BLUR_THRESHOLD=100.0      # Laplacian variance; below = blurry
#QIMC_NOISE_THRESHOLD=8.0       # estimated noise sigma; above = noisy
#QIMC_HIGHLIGHT_CLIP_THRESHOLD=1.0  # % pixels > 250 (blown highlights)
#QIMC_SHADOW_CLIP_THRESHOLD=1.0    # % pixels < 5  (crushed blacks)

# ── Video ──────────────────────────────────────────────────────────────────────
# Frames per second to sample from video for analysis
# Higher = more accurate but slower. 2.0 is fast; 30.0 analyses every frame.
QIMC_VIDEO_SAMPLE_FPS=2.0
# Mean optical flow (px) below which the video is classified as VIDEO_STATIC
QIMC_MOTION_FLOW_THRESHOLD=2.0

# ── Preview Crop ───────────────────────────────────────────────────────────────
# Auto-detect and crop camera UI chrome from ADB screen recordings
QIMC_PREVIEW_CROP_ENABLED=true

# ── Storage ────────────────────────────────────────────────────────────────────
QIMC_REPORTS_DIR=./data/reports

# ── Server ─────────────────────────────────────────────────────────────────────
QIMC_HOST=0.0.0.0
QIMC_PORT=8080
QIMC_LOG_LEVEL=info
