# Profile: LOW — unstable rig / CoreXY rail vibration / outdoor / handheld
# Copy to .env:  cp .env.low .env
QIMC_QUALITY_PROFILE=low
QIMC_DEVICE=auto
QIMC_NR_METRICS=brisque,niqe
QIMC_USE_NEURAL_NR=false
QIMC_NEURAL_NR_METRIC=musiq
QIMC_FR_METRICS=psnr,lpips
QIMC_VIDEO_SAMPLE_FPS=2.0
QIMC_MOTION_FLOW_THRESHOLD=2.0
QIMC_PREVIEW_CROP_ENABLED=true
QIMC_REPORTS_DIR=./data/reports
QIMC_HOST=0.0.0.0
QIMC_PORT=8080
QIMC_LOG_LEVEL=info
