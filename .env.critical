# Profile: CRITICAL — robotic / pixel-aligned rig / professional studio
# Copy to .env:  cp .env.critical .env
QIMC_QUALITY_PROFILE=critical
QIMC_DEVICE=auto
QIMC_NR_METRICS=brisque,niqe
QIMC_USE_NEURAL_NR=false
QIMC_NEURAL_NR_METRIC=musiq
QIMC_FR_METRICS=ssim,ms_ssim,psnr,lpips,dists
QIMC_VIDEO_SAMPLE_FPS=5.0
QIMC_MOTION_FLOW_THRESHOLD=1.0
QIMC_PREVIEW_CROP_ENABLED=true
QIMC_REPORTS_DIR=./data/reports
QIMC_HOST=0.0.0.0
QIMC_PORT=8080
QIMC_LOG_LEVEL=info
